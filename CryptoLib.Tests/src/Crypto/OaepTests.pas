    (APubParam as IRsaKeyParameters).Exponent,
    TBigInteger.Create(1, DecodeHex(PrivExp1027Hex)),
    TBigInteger.Create(1, DecodeHex(Prime11027Hex)),
    TBigInteger.Create(1, DecodeHex(Prime21027Hex)),
    TBigInteger.Create(1, DecodeHex(PrimeExp11027Hex)),
    TBigInteger.Create(1, DecodeHex(PrimeExp21027Hex)),
    TBigInteger.Create(1, DecodeHex(CrtCoef1027Hex)));
