    TBigInteger.Create(1, DecodeHex(Modulus1027Hex)),
    TBigInteger.Create(1, DecodeHex(PubExp1027Hex)));
end;

function TTestOaep.Get1027PrivParam(
  const APubParam: IAsymmetricKeyParameter): IAsymmetricKeyParameter;
begin
