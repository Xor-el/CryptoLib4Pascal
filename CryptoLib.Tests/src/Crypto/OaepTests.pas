procedure TTestOaep.TestBaseOaep;
begin
  DoBaseOaepTest(1, FPubKeyEnc1, FPrivKeyEnc1, FOutput1);
  DoBaseOaepTest(2, FPubKeyEnc2, FPrivKeyEnc2, FOutput2);
  DoBaseOaepTest(3, FPubKeyEnc3, FPrivKeyEnc3, FOutput3);
end;

procedure TTestOaep.TestOaepVectors1024;
var
  LPubParam, LPrivParam: IAsymmetricKeyParameter;
begin
  LPubParam := Get1024PubParam;
  LPrivParam := Get1024PrivParam(LPubParam);

  DoOaepVecTest(1024, 1, LPubParam, LPrivParam,
    DecodeHex(Seed1024_1Hex), DecodeHex(Input1024_1Hex), DecodeHex(Output1024_1Hex));
  DoOaepVecTest(1024, 2, LPubParam, LPrivParam,
    DecodeHex(Seed1024_2Hex), DecodeHex(Input1024_2Hex), DecodeHex(Output1024_2Hex));
  DoOaepVecTest(1024, 3, LPubParam, LPrivParam,
    DecodeHex(Seed1024_3Hex), DecodeHex(Input1024_3Hex), DecodeHex(Output1024_3Hex));
  DoOaepVecTest(1024, 4, LPubParam, LPrivParam,
    DecodeHex(Seed1024_4Hex), DecodeHex(Input1024_4Hex), DecodeHex(Output1024_4Hex));
  DoOaepVecTest(1024, 5, LPubParam, LPrivParam,
    DecodeHex(Seed1024_5Hex), DecodeHex(Input1024_5Hex), DecodeHex(Output1024_5Hex));
  DoOaepVecTest(1024, 6, LPubParam, LPrivParam,
    DecodeHex(Seed1024_6Hex), DecodeHex(Input1024_6Hex), DecodeHex(Output1024_6Hex));
end;

procedure TTestOaep.TestOaepVectors1027;
var
  LPubParam, LPrivParam: IAsymmetricKeyParameter;
begin
  LPubParam := Get1027PubParam;
  LPrivParam := Get1027PrivParam(LPubParam);

  DoOaepVecTest(1027, 1, LPubParam, LPrivParam,
    DecodeHex(Seed1027_1Hex), DecodeHex(Input1027_1Hex), DecodeHex(Output1027_1Hex));
  DoOaepVecTest(1027, 2, LPubParam, LPrivParam,
    DecodeHex(Seed1027_2Hex), DecodeHex(Input1027_2Hex), DecodeHex(Output1027_2Hex));
  DoOaepVecTest(1027, 3, LPubParam, LPrivParam,
    DecodeHex(Seed1027_3Hex), DecodeHex(Input1027_3Hex), DecodeHex(Output1027_3Hex));
  DoOaepVecTest(1027, 4, LPubParam, LPrivParam,
    DecodeHex(Seed1027_4Hex), DecodeHex(Input1027_4Hex), DecodeHex(Output1027_4Hex));
  DoOaepVecTest(1027, 5, LPubParam, LPrivParam,
    DecodeHex(Seed1027_5Hex), DecodeHex(Input1027_5Hex), DecodeHex(Output1027_5Hex));
  DoOaepVecTest(1027, 6, LPubParam, LPrivParam,
    DecodeHex(Seed1027_6Hex), DecodeHex(Input1027_6Hex), DecodeHex(Output1027_6Hex));
end;

procedure TTestOaep.TestHighByteError;
begin
  DoTestForHighByteError('invalidCiphertextOaepTest 1024', 1024);
end;

procedure TTestOaep.TestMixedDigest;
var
  LPubParam, LPrivParam: IAsymmetricKeyParameter;
  LCipher: IAsymmetricBlockCipher;
  LInput, LEnc, LOutput: TCryptoLibByteArray;
  LCBuf: IBufferedCipher;
  LI: Integer;
begin
  LPubParam := Get1027PubParam;
  LPrivParam := Get1027PrivParam(LPubParam);

  // SHA-256 hash, SHA-1 MGF1
  LCipher := TOaepEncoding.Create(TRsaEngine.Create() as IRsaEngine,
    TDigestUtilities.GetDigest('SHA-256'),
    TDigestUtilities.GetDigest('SHA-1'), nil);

  LCipher.Init(True,
    TParametersWithRandom.Create(LPubParam as ICipherParameters,
      TSecureRandom.Create() as ISecureRandom) as IParametersWithRandom);

  SetLength(LInput, 10);
  LEnc := LCipher.ProcessBlock(LInput, 0, System.Length(LInput));

  LCipher.Init(False, LPrivParam as ICipherParameters);
  LOutput := LCipher.ProcessBlock(LEnc, 0, System.Length(LEnc));

  for LI := 0 to System.Length(LInput) - 1 do
  begin
    if LOutput[LI] <> LInput[LI] then
    begin
      Fail('mixed digest failed decoding');
      Exit;
    end;
  end;

  // Verify CipherUtilities string-based mixed digest
  LCBuf := TCipherUtilities.GetCipher(
    'RSA/NONE/OAEPWITHSHA-256ANDMGF1WITHSHA-1PADDING');

  LCBuf.Init(False, LPrivParam as ICipherParameters);
  LOutput := LCBuf.DoFinal(LEnc, 0, System.Length(LEnc));

  CheckTrue(AreEqual(LInput, LOutput),
    'CipherUtilities mixed digest failed decoding');

  // SHA-1 hash, SHA-256 MGF1, with encoding params
  LCipher := TOaepEncoding.Create(TRsaEngine.Create() as IRsaEngine,
    TDigestUtilities.GetDigest('SHA-1'),
    TDigestUtilities.GetDigest('SHA-256'),
    DecodeHex('00000000000000000000'));

  LCipher.Init(True,
    TParametersWithRandom.Create(LPubParam as ICipherParameters,
      TSecureRandom.Create() as ISecureRandom) as IParametersWithRandom);

  LOutput := LCipher.ProcessBlock(LInput, 0, System.Length(LInput));

  LCipher.Init(False, LPrivParam as ICipherParameters);
  LOutput := LCipher.ProcessBlock(LOutput, 0, System.Length(LOutput));

  for LI := 0 to System.Length(LInput) - 1 do
  begin
    if LOutput[LI] <> LInput[LI] then
    begin
      Fail('mixed digest with encoding params failed decoding');
      Exit;
    end;
  end;
end;

procedure TTestOaep.TestOaep2048Sha256;
var
  LPub2048, LPri2048: IAsymmetricKeyParameter;
  LCipher: IAsymmetricBlockCipher;
  LInput, LOutput: TCryptoLibByteArray;
begin
  LPub2048 := TPublicKeyFactory.CreateKey(DecodeHex(EncPub2048Hex));
  LPri2048 := TPrivateKeyFactory.CreateKey(DecodeHex(EncPri2048Hex));

  LInput := DecodeHex(Input2048Hex);
  LCipher := TOaepEncoding.Create(TRsaEngine.Create() as IRsaEngine,
    TDigestUtilities.GetDigest('SHA-256'));

  LCipher.Init(True,
    TParametersWithRandom.Create(LPub2048 as ICipherParameters,
      TVecRand.Create(DecodeHex(EncPub2048Hex)) as IVecRand) as IParametersWithRandom);

  LOutput := LCipher.ProcessBlock(LInput, 0, System.Length(LInput));

  CheckTrue(AreEqual(DecodeHex(Output2048Hex), LOutput),
    '2048-bit SHA-256 OAEP encryption failed');

  LCipher.Init(False, LPri2048 as ICipherParameters);
  LOutput := LCipher.ProcessBlock(LOutput, 0, System.Length(LOutput));

  CheckTrue(AreEqual(LInput, LOutput),
    '2048-bit SHA-256 OAEP decryption failed');
end;

